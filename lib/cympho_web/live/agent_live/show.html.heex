<div class="p-6 lg:p-8 max-w-4xl mx-auto">
  <.header title={@agent.name}>
    <:actions>
      <.app_link navigate={~p"/agents"} class="bg-white/[0.05] hover:bg-white/[0.08] border border-border text-text-secondary hover:text-text-primary font-510 text-sm px-4 py-2 rounded-md transition-colors">
        Back
      </.app_link>
      <.app_link navigate={~p"/agents/#{@agent.id}/edit"} class="bg-brand hover:bg-accent text-white font-510 text-sm px-4 py-2 rounded-md transition-colors">
        Edit
      </.app_link>
    </:actions>
  </.header>

  <div class="space-y-6">
    <div class="flex items-center gap-3">
      <.badge variant="agent" value={to_string(@agent.status)} />
      <.badge variant="pill" value={role_label(@agent.role)} />
    </div>

    <div class="bg-surface border border-border rounded-card p-5 space-y-4">
      <h3 class="text-xs font-510 text-text-secondary uppercase tracking-wider">Instructions</h3>
      <p class="text-sm text-text-secondary leading-relaxed whitespace-pre-wrap">
        {@agent.instructions}
      </p>
    </div>

    <%= if @agent.instructions_path do %>
      <div class="bg-surface border border-border rounded-card p-5 space-y-2">
        <h3 class="text-xs font-510 text-text-secondary uppercase tracking-wider">Instructions File</h3>
        <p class="text-sm text-text-secondary">
          <span class="text-brand">{@agent.instructions_path}</span>
        </p>
      </div>
    <% end %>

    <div class="bg-surface border border-border rounded-card p-5 space-y-2">
      <h3 class="text-xs font-510 text-text-secondary uppercase tracking-wider">Configuration</h3>
      <div class="flex items-center gap-4">
        <span class="text-sm text-text-secondary">Max concurrent jobs: <span class="text-brand">{@agent.max_concurrent_jobs}</span></span>
        <.badge variant="pill" value={@agent.adapter || "No adapter"} />
      </div>
    </div>

    <!-- Wake History -->
    <div class="bg-surface border border-border rounded-card p-5 space-y-4">
      <h3 class="text-xs font-510 text-text-secondary uppercase tracking-wider">Wake History</h3>
      <div :if={Enum.empty?(@wake_history)} class="text-sm text-text-tertiary py-4 text-center">
        No wake history available.
      </div>
      <div :if={not Enum.empty?(@wake_history)} class="space-y-2">
        <%= for wake <- Enum.take(@wake_history, 10) do %>
          <div class="flex items-center justify-between text-xs border-b border-border/50 pb-2">
            <div class="flex items-center gap-2">
              <span class="text-text-secondary">{wake_reason_label(wake.reason)}</span>
              <%= if wake.issue_id do %>
                <.app_link navigate={~p"/issues/#{wake.issue_id}"} class="text-brand hover:text-accent">
                  Issue
                </.app_link>
              <% end %>
            </div>
            <span class="text-text-quaternary">{format_datetime(wake.inserted_at)}</span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="text-xs text-text-quaternary">
      Created {format_datetime(@agent.inserted_at)}
    </div>
  </div>
</div>
