<div class="p-6 lg:p-8 max-w-6xl mx-auto">
  <.header title={@page_title}>
    <:actions>
      <%= if show_spawn_button?(@current_agent) do %>
        <.live_component
          module={CymphoWeb.SpawnAgentComponent}
          id="spawn-agent"
          current_agent={@current_agent}
        />
      <% else %>
        <.app_link
          navigate={~p"/agents/new"}
          class="bg-brand hover:bg-accent text-white font-510 text-sm px-4 py-2 rounded-md transition-colors inline-flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 4v16m8-8H4"
            />
          </svg>
          New Agent
        </.app_link>
      <% end %>
    </:actions>
  </.header>

  <div
    :if={@flash && @flash[:info]}
    class="mb-6 bg-success/10 border border-success/20 text-success text-sm px-4 py-3 rounded-md"
  >
    {@flash[:info]}
  </div>

  <div
    :if={@flash && @flash[:error]}
    class="mb-6 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-md"
  >
    {@flash[:error]}
  </div>

  <!-- Status Dashboard -->
  <div class="grid grid-cols-5 gap-3 mb-6">
    <div class="bg-surface border border-border rounded-card p-4 text-center">
      <div class="text-2xl font-510 text-text-primary">{@status_counts[:idle]}</div>
      <div class="text-xs text-text-secondary mt-1">Idle</div>
    </div>
    <div class="bg-surface border border-brand/30 rounded-card p-4 text-center">
      <div class="text-2xl font-510 text-brand">{@status_counts[:running]}</div>
      <div class="text-xs text-text-secondary mt-1">Running</div>
    </div>
    <div class="bg-surface border border-red-500/30 rounded-card p-4 text-center">
      <div class="text-2xl font-510 text-red-400">{@status_counts[:error]}</div>
      <div class="text-xs text-text-secondary mt-1">Error</div>
    </div>
    <div class="bg-surface border border-border rounded-card p-4 text-center">
      <div class="text-2xl font-510 text-text-primary">{@status_counts[:sleeping]}</div>
      <div class="text-xs text-text-secondary mt-1">Sleeping</div>
    </div>
    <div class="bg-surface border border-border rounded-card p-4 text-center">
      <div class="text-2xl font-510 text-text-primary">{@status_counts[:offline]}</div>
      <div class="text-xs text-text-secondary mt-1">Offline</div>
    </div>
  </div>

  <!-- Active Sessions -->
  <div :if={@status_counts[:running] > 0} class="mb-6 space-y-3">
    <h2 class="text-xs font-510 text-text-secondary uppercase tracking-wider">Active Sessions</h2>
    <div class="space-y-2">
      <%= for agent <- Enum.filter(@agents, fn a -> a.status == :running end) do %>
        <% progress = Map.get(@session_progress, agent.id) %>
        <div class="bg-surface border border-brand/20 rounded-card p-4 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-brand animate-pulse"></span>
              <span class="text-sm font-510 text-text-primary">{agent.name}</span>
            </div>
            <%= if progress && progress[:issue] do %>
              <span class="text-xs text-text-secondary">
                Working on: <span class="text-text-primary">{progress[:issue].title}</span>
              </span>
            <% end %>
            <%= if progress do %>
              <span class="text-xs text-text-quaternary">
                Turn {progress[:turn_count]} &middot; {format_elapsed(progress[:elapsed_seconds])}
              </span>
            <% end %>
          </div>
          <button
            type="button"
            class="bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 font-510 text-xs px-3 py-1.5 rounded-md transition-colors"
            phx-click="kill_session"
            phx-value-id={agent.id}
            data-confirm="Kill session for this agent?"
          >
            Kill Session
          </button>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Agent Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <.card :for={agent <- @agents} id={"agent-#{agent.id}"}>
      <div class="p-5 space-y-3">
        <div class="flex items-center justify-between">
          <h3 class="text-sm font-510 text-text-primary truncate">{agent.name}</h3>
          <.badge variant="agent" value={to_string(agent.status)} />
        </div>
        <p class="text-xs text-text-tertiary">
          Role: {role_label(agent.role)}
        </p>
        <div class="flex items-center gap-2">
          <.badge variant="pill" value={agent.adapter || "No adapter"} />
        </div>
        <div class="flex items-center gap-2 pt-2">
          <.app_link
            navigate={~p"/agents/#{agent.id}"}
            class="bg-white/[0.05] hover:bg-white/[0.08] border border-border text-text-secondary hover:text-text-primary font-510 text-xs px-3 py-1.5 rounded-md transition-colors"
          >
            View
          </.app_link>
          <button
            :if={agent.status == :running}
            type="button"
            class="bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 font-510 text-xs px-3 py-1.5 rounded-md transition-colors"
            phx-click="kill_session"
            phx-value-id={agent.id}
            data-confirm="Kill session for this agent?"
          >
            Kill
          </button>
          <button
            type="button"
            class="bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 font-510 text-xs px-3 py-1.5 rounded-md transition-colors"
            phx-click="delete_agent"
            phx-value-id={agent.id}
            data-confirm="Delete this agent?"
          >
            Delete
          </button>
        </div>
      </div>
    </.card>
  </div>

  <div
    :if={Enum.empty?(@agents)}
    class="flex flex-col items-center justify-center py-20 text-center"
  >
    <div class="w-12 h-12 rounded-full bg-white/[0.05] flex items-center justify-center mb-4">
      <svg
        class="w-6 h-6 text-text-tertiary"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.131A8 8 0 008 3.239c-4.828 4.596-5.212 11.611-.647 16.656A21.866 21.866 0 0012 21.942a21.866 21.866 0 003.99-.385M19.337 17.81a15.79 15.79 0 01-2.326 1.575"
        />
      </svg>
    </div>
    <p class="text-sm text-text-tertiary mb-4">No agents yet.</p>
    <.app_link
      navigate={~p"/agents/new"}
      class="bg-white/[0.05] hover:bg-white/[0.08] border border-border text-text-secondary hover:text-text-primary font-510 text-sm px-4 py-2 rounded-md transition-colors"
    >
      Create your first agent
    </.app_link>
  </div>
</div>
