<.page size="wide">
  <.header
    title={@page_title}
    subtitle="Autonomous operators, runtime health, and execution capacity."
  >
    <:actions>
      <.app_link
        navigate={~p"/org-chart"}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-panel px-3 py-2 text-sm font-510 text-text-secondary hover:bg-surface-hover hover:text-text-primary"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
          />
        </svg>
        Org Chart
      </.app_link>
      <.app_link
        navigate={~p"/agents/new"}
        class="inline-flex items-center gap-2 rounded-lg bg-brand px-3 py-2 text-sm font-510 text-white hover:bg-accent-hover"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"
          />
        </svg>
        New Agent
      </.app_link>
    </:actions>
  </.header>

  <div
    :if={@flash && @flash[:info]}
    class="mb-4 rounded-lg border border-success/20 bg-success/10 px-4 py-3 text-sm text-success"
  >
    {@flash[:info]}
  </div>

  <div
    :if={@flash && @flash[:error]}
    class="mb-4 rounded-lg border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-300"
  >
    {@flash[:error]}
  </div>

  <div class="mb-4 grid grid-cols-2 gap-3 md:grid-cols-5">
    <.metric label="Idle" value={@status_counts[:idle] || 0} />
    <.metric label="Running" value={@status_counts[:running] || 0} tone="brand" />
    <.metric label="Error" value={@status_counts[:error] || 0} tone="danger" />
    <.metric
      label="Paused"
      value={(@status_counts[:sleeping] || 0) + (@status_counts[:paused] || 0)}
      tone="warning"
    />
    <.metric
      label="Stopped"
      value={(@status_counts[:offline] || 0) + (@status_counts[:terminated] || 0)}
    />
  </div>

  <.panel :if={Enum.empty?(@agents)}>
    <.empty_state
      title="No agents yet"
      message="Create the CEO, CTO, and engineering operators that run the company."
    >
      <:actions>
        <.app_link
          navigate={~p"/agents/new"}
          class="rounded-lg bg-brand px-3 py-2 text-sm font-510 text-white hover:bg-accent-hover"
        >
          Create agent
        </.app_link>
      </:actions>
    </.empty_state>
  </.panel>

  <div :if={!Enum.empty?(@agents)} class="space-y-4">
    <.panel
      :for={{group, agents} <- agent_groups(@agents)}
      class="overflow-visible"
    >
      <div class="flex items-center justify-between border-b border-border px-4 py-3">
        <div>
          <h2 class="text-xs font-590 uppercase tracking-[0.08em] text-text-quaternary">
            {role_label(group)}
          </h2>
          <p class="mt-0.5 text-xs text-text-quaternary">{length(agents)} agent(s)</p>
        </div>
      </div>

      <div class="hidden grid-cols-[minmax(220px,1fr)_110px_110px_120px_minmax(170px,1fr)_100px_48px] gap-4 border-b border-border bg-panel/70 px-4 py-2 text-[11px] font-590 uppercase tracking-[0.08em] text-text-quaternary lg:grid">
        <span>Agent</span>
        <span>Status</span>
        <span>Health</span>
        <span>Adapter</span>
        <span>Runtime</span>
        <span>Heartbeat</span>
        <span class="text-right">Actions</span>
      </div>

      <div
        :for={agent <- agents}
        id={"agent-row-#{agent.id}"}
        class="group grid gap-3 border-b border-border px-4 py-3 last:border-b-0 hover:bg-surface-hover/60 lg:grid-cols-[minmax(220px,1fr)_110px_110px_120px_minmax(170px,1fr)_100px_48px] lg:items-center lg:gap-4"
      >
        <.app_link navigate={~p"/agents/#{agent.id}"} class="min-w-0">
          <div class="flex min-w-0 items-center gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border bg-surface text-xs font-590 text-brand">
              {agent_initials(agent)}
            </div>
            <div class="min-w-0">
              <p class="truncate text-sm font-590 text-text-primary">{agent.name}</p>
              <p class="mt-0.5 truncate text-xs text-text-tertiary">
                {agent.title || "Role: #{role_label(agent.role)}"}
              </p>
            </div>
          </div>
        </.app_link>

        <div>
          <span class={"inline-flex rounded-full border px-2 py-0.5 text-xs font-510 #{status_pill_class(agent.status)}"}>
            {status_label(agent.status)}
          </span>
        </div>

        <div>
          <span class={"inline-flex rounded-full border px-2 py-0.5 text-xs font-510 #{health_pill_class(agent.health_status)}"}>
            {agent.health_status |> to_string() |> String.replace("_", " ")}
          </span>
        </div>

        <div class="truncate text-xs text-text-tertiary">
          {adapter_label(Map.get(agent, :adapter))}
        </div>

        <div class="min-w-0 text-xs">
          <p class="truncate font-mono text-text-secondary">{runtime_command(agent)}</p>
          <p class="mt-0.5 truncate text-text-quaternary">{runtime_model(agent)}</p>
        </div>

        <div class="text-xs text-text-quaternary">
          {format_heartbeat(agent)}
        </div>

        <div class="flex justify-end">
          <.overflow_menu label={"Actions for #{agent.name}"}>
            <.menu_item navigate={~p"/agents/#{agent.id}"}>View profile</.menu_item>
            <.menu_item navigate={~p"/agents/#{agent.id}/edit"}>Edit settings</.menu_item>
            <.menu_item
              :if={agent.status == :running}
              phx-click="kill_session"
              phx-value-id={agent.id}
              data-confirm="Stop this agent's session?"
            >
              Stop session
            </.menu_item>
            <.menu_item
              :if={agent.status == :idle}
              phx-click="pause_agent"
              phx-value-id={agent.id}
            >
              Pause
            </.menu_item>
            <.menu_item
              :if={agent.status in [:sleeping, :paused]}
              phx-click="resume_agent"
              phx-value-id={agent.id}
            >
              Resume
            </.menu_item>
            <.menu_item
              danger
              phx-click="terminate_agent"
              phx-value-id={agent.id}
              data-confirm="Terminate this agent? This will stop any running sessions."
            >
              Terminate
            </.menu_item>
            <.menu_item
              danger
              phx-click="delete_agent"
              phx-value-id={agent.id}
              data-confirm="Delete this agent?"
            >
              Delete
            </.menu_item>
          </.overflow_menu>
        </div>
      </div>
    </.panel>
  </div>
</.page>
