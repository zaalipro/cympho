<div class="p-6 lg:p-8 max-w-2xl mx-auto">
  <%= if @pending_approval_id do %>
    <div class="mb-4 p-4 bg-blue-500/10 border border-blue-500/20 rounded-lg">
      <p class="text-sm text-blue-400">
        Agent hire requires board approval. A request has been submitted and is pending review.
        <.app_link
          navigate={~p"/board-approvals/#{@pending_approval_id}"}
          class="text-blue-400 underline hover:text-blue-300"
        >
          View approval request
        </.app_link>
      </p>
    </div>
  <% end %>

  <.header title="New Agent">
    <:actions>
      <.app_link
        navigate={~p"/agents"}
        class="bg-surface hover:bg-surface-hover border border-border text-text-secondary hover:text-text-primary font-510 text-sm px-4 py-2 rounded-lg transition-colors"
      >
        Cancel
      </.app_link>
    </:actions>
  </.header>

  <.simple_form for={@form} phx-submit="save">
    <.input field={@form[:name]} label="Name" />
    <.input field={@form[:instructions]} label="Instructions" type="textarea" />
    <.select
      name="agent[role]"
      label="Role"
      options={[Engineer: "engineer", CEO: "ceo", CTO: "cto"]}
    />
    <.input field={@form[:adapter]} label="Adapter" placeholder="e.g., anthropic" />

    <:actions>
      <.button type="submit">Create Agent</.button>
    </:actions>
  </.simple_form>
</div>
