<div class="p-6 lg:p-8 max-w-2xl mx-auto">
  <%= if @pending_approval_id do %>
    <div class="mb-4 p-4 bg-blue-500/10 border border-blue-500/20 rounded-lg">
      <p class="text-sm text-blue-400">
        Agent role change requires board approval. A request has been submitted and is pending review.
        <.app_link
          navigate={~p"/approvals/#{@pending_approval_id}"}
          class="text-blue-400 underline hover:text-blue-300"
        >
          View approval request
        </.app_link>
      </p>
    </div>
  <% end %>

  <.header title="Edit Agent">
    <:actions>
      <.app_link
        navigate={~p"/agents"}
        class="bg-white/[0.05] hover:bg-white/[0.08] border border-border text-text-secondary hover:text-text-primary font-510 text-sm px-4 py-2 rounded-md transition-colors"
      >
        Cancel
      </.app_link>
    </:actions>
  </.header>

  <.simple_form for={@form} phx-submit="save">
    <.input field={@form[:name]} label="Name" />
    <.input field={@form[:instructions]} label="Instructions" type="textarea" />
    <.input
      field={@form[:instructions_path]}
      label="Instructions File Path"
      placeholder="e.g., agents/engineer/AGENTS.md"
    />

    <div class="space-y-1.5">
      <label class="block text-xs font-510 text-text-secondary">Max Concurrent Jobs</label>
      <div class="flex items-center gap-3">
        <input
          type="range"
          name="agent[max_concurrent_jobs]"
          min="1"
          max="10"
          value={@form[:max_concurrent_jobs].value || 3}
          class="w-full h-2 bg-white/[0.05] rounded-lg appearance-none cursor-pointer accent-brand"
        />
        <span class="text-sm text-brand font-510 w-8 text-center">
          {@form[:max_concurrent_jobs].value || 3}
        </span>
      </div>
      <p class="text-xs text-text-quaternary">
        Number of issues this agent can handle simultaneously
      </p>
    </div>

    <.select
      name="agent[role]"
      label="Role"
      options={[
        Engineer: "engineer",
        CEO: "ceo",
        CTO: "cto",
        Designer: "designer",
        PM: "product_manager"
      ]}
    />
    <.input field={@form[:adapter]} label="Adapter" placeholder="e.g., anthropic" />

    <:actions>
      <.button type="submit">Update Agent</.button>
    </:actions>
  </.simple_form>
</div>
