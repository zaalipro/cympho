  <div class="kanban-column" id="column-blocked">
    <div class="column-header">
      <h2>Blocked</h2>
      <span class="issue-count"><%= length(blocked_issues(@issues)) %></span>
    </div>
    <div class="column-cards">
      <%= for issue <- blocked_issues(@issues) do %>
        <div class="kanban-card" id={"issue-#{issue.id}"}>
          <div class="card-title"><%= issue.title %></div>
          <div class="card-meta">
            <span class={"priority-badge priority-#{issue.priority}"}><%= issue.priority %></span>
            <span class="comment-count"><%= length(issue.comments) %> comments</span>
            <%= if issue.assignee do %>
              <% hb_state = get_heartbeat_state(@agent_heartbeat_states, issue.assignee.id) %>
              <span class={"agent-badge heartbeat-#{hb_state.status}"}>
                <%= issue.assignee.name %>: <%= heartbeat_status_label(hb_state, @issues) %>
              </span>
            <% end %>
            <%= if issue.github_pr_url do %>
              <a href={issue.github_pr_url} target="_blank" class="pr-badge" title="GitHub PR">
                PR
              </a>
            <% end %>
          </div>
          <div class="card-actions">
            <%= for next_status <- valid_next_statuses(:blocked) do %>
              <button
                type="button"
                class="transition-btn"
                phx-click="transition_issue"
                phx-value-id={issue.id}
                phx-value-to_status={next_status}
              >
                <%= status_label(next_status) %>
