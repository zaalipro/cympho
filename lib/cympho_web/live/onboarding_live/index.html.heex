<div class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <!-- Progress dots -->
    <div class="flex items-center justify-center gap-2 mb-8">
      <%= for {step, idx} <- Enum.with_index(@steps) do %>
        <div class={
          "w-2 h-2 rounded-full transition-all duration-200 " <>
          cond do
            idx < @current_step -> "bg-accent w-6"
            idx == @current_step -> "bg-accent"
            true -> "bg-white/10"
          end
        }>
        </div>
      <% end %>
    </div>
    
<!-- Step content -->
    <div class="text-center mb-8">
      <h1 class="text-2xl font-590 tracking-tight text-text-primary mb-2">
        {@steps |> Enum.at(@current_step) |> Map.get(:title)}
      </h1>
      <p class="text-sm text-text-secondary">
        {@steps |> Enum.at(@current_step) |> Map.get(:description)}
      </p>
    </div>
    
<!-- Welcome step -->
    <div :if={@current_step == 0} class="bg-panel border border-border rounded-2xl p-6 mb-6">
      <div class="flex flex-col items-center gap-4 text-center">
        <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"
            />
          </svg>
        </div>
        <div>
          <p class="text-sm text-text-secondary mb-2">
            Cympho helps you manage projects with AI-powered agents that can take on issues, run tasks, and collaborate autonomously.
          </p>
          <ul class="text-sm text-text-tertiary space-y-1.5 text-left">
            <li class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-emerald shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Track issues with kanban boards
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-emerald shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Assign AI agents to automate work
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-emerald shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Set goals and track progress
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="w-4 h-4 text-emerald shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Keyboard-first for speed
            </li>
          </ul>
        </div>
      </div>
    </div>
    
<!-- Workspace step -->
    <div :if={@current_step == 1} class="bg-panel border border-border rounded-2xl p-6 mb-6">
      <div class="space-y-4">
        <div class="flex items-start gap-3 p-3 bg-subtle border border-border rounded-lg">
          <svg
            class="w-5 h-5 text-accent shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"
            />
          </svg>
          <div>
            <p class="text-sm font-510 text-text-primary">Create Projects</p>
            <p class="text-xs text-text-tertiary mt-0.5">
              Organize work into projects with unique prefixes like LLM-42
            </p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-subtle border border-border rounded-lg">
          <svg
            class="w-5 h-5 text-accent shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.131A8 8 0 008 3.239c-4.828 4.596-5.212 11.611-.647 16.656A21.866 21.866 0 0012 21.942a21.866 21.866 0 003.99-.385M19.337 17.81a15.79 15.79 0 01-2.326 1.575"
            />
          </svg>
          <div>
            <p class="text-sm font-510 text-text-primary">Hire Agents</p>
            <p class="text-xs text-text-tertiary mt-0.5">
              Deploy AI agents that autonomously pick up and complete issues
            </p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-3 bg-subtle border border-border rounded-lg">
          <svg
            class="w-5 h-5 text-accent shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"
            />
          </svg>
          <div>
            <p class="text-sm font-510 text-text-primary">Define Goals</p>
            <p class="text-xs text-text-tertiary mt-0.5">
              Set milestones and track progress across projects
            </p>
          </div>
        </div>
      </div>
    </div>
    
<!-- Shortcuts step -->
    <div :if={@current_step == 2} class="bg-panel border border-border rounded-2xl p-6 mb-6">
      <div class="space-y-3">
        <div class="flex items-center justify-between text-sm">
          <span class="text-text-secondary">Command palette</span>
          <div class="flex gap-1"><kbd class="kbd">Cmd</kbd><kbd class="kbd">K</kbd></div>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-text-secondary">New issue</span>
          <kbd class="kbd">C</kbd>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-text-secondary">Go to Issues</span>
          <div class="flex gap-1"><kbd class="kbd">G</kbd><kbd class="kbd">I</kbd></div>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-text-secondary">Go to Board</span>
          <div class="flex gap-1"><kbd class="kbd">G</kbd><kbd class="kbd">K</kbd></div>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-text-secondary">Show shortcuts</span>
          <kbd class="kbd">?</kbd>
        </div>
      </div>
    </div>
    
<!-- Ready step -->
    <div :if={@current_step == 3} class="bg-panel border border-border rounded-2xl p-6 mb-6">
      <div class="flex flex-col items-center gap-4 text-center">
        <div class="w-16 h-16 rounded-full bg-emerald/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-emerald" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
        </div>
        <div>
          <p class="text-sm text-text-secondary">
            You're ready to start using Cympho. Create your first project or jump straight to the issue board.
          </p>
        </div>
        <div class="flex gap-3 w-full">
          <.app_link
            navigate={~p"/projects/new"}
            class="flex-1 text-center bg-surface hover:bg-surface-hover border border-border text-text-secondary hover:text-text-primary font-510 text-sm px-4 py-2.5 rounded-lg transition-colors"
          >
            Create Project
          </.app_link>
          <.app_link
            navigate={~p"/issues"}
            class="flex-1 text-center bg-brand hover:bg-accent text-white font-510 text-sm px-4 py-2.5 rounded-lg transition-colors"
          >
            Go to Issues
          </.app_link>
        </div>
      </div>
    </div>
    
<!-- Navigation buttons -->
    <div class="flex items-center justify-between">
      <button
        :if={@current_step > 0}
        type="button"
        phx-click="prev_step"
        class="text-sm text-text-tertiary hover:text-text-secondary transition-colors px-3 py-2 min-h-[44px]"
      >
        Back
      </button>
      <button
        :if={@current_step == 0}
        type="button"
        phx-click="skip"
        class="text-sm text-text-quaternary hover:text-text-tertiary transition-colors px-3 py-2 min-h-[44px]"
      >
        Skip setup
      </button>
      <div class="flex items-center gap-3 ml-auto">
        <span class="text-xs text-text-quaternary">{@current_step + 1} of {length(@steps)}</span>
        <button
          type="button"
          phx-click="next_step"
          class="bg-brand hover:bg-accent text-white font-510 text-sm px-5 py-2.5 rounded-lg transition-colors min-h-[44px]"
        >
          {if @current_step == length(@steps) - 1 do
            "Get Started"
          else
            "Continue"
          end}
        </button>
      </div>
    </div>
  </div>
</div>
