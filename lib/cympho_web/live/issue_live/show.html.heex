<div
  id="issue-show"
  data-clean-url={@gate_clean_url}
  class="flex flex-col lg:flex-row min-h-screen bg-canvas"
>
  <!-- Main Timeline Column -->
  <div class="flex-1 flex flex-col min-w-0">
    <CymphoWeb.IssueLive.Show.Header.header
      issue={@issue}
      editing={@editing}
      pending_wake={@pending_wake}
    />
    <div
      :if={@flash["info"]}
      class="mx-4 mt-4 rounded-lg border border-brand/25 bg-brand/10 px-3 py-2 text-sm text-brand lg:mx-6"
    >
      {@flash["info"]}
    </div>
    <div
      :if={@flash["error"]}
      class="mx-4 mt-4 rounded-lg border border-red-500/25 bg-red-500/10 px-3 py-2 text-sm text-red-300 lg:mx-6"
    >
      {@flash["error"]}
    </div>
    
<CymphoWeb.IssueLive.Show.Description.description issue={@issue} editing={@editing} />

    <% gate_resolution = review_gate_resolution(assigns) %>

    <.issue_digest_panel
      issue={@issue}
      runs={@runs}
      work_products={@work_products}
      child_issues={@child_issues}
      agents={@all_agents}
      review_gate_actions={gate_resolution.actions}
      review_nudges={gate_resolution.nudges}
    />

    <CymphoWeb.IssueLive.Show.ReviewGates.review_gates
      issue={@issue}
      runs={@runs}
      work_products={@work_products}
      child_issues={@child_issues}
      all_agents={@all_agents}
      orchestrator_enabled?={@orchestrator_enabled?}
      show_work_product_form={@show_work_product_form}
      work_product_form={@work_product_form}
    />

    <CymphoWeb.IssueLive.Show.ExecutionBrief.execution_brief
      issue={@issue}
      runs={@runs}
      work_products={@work_products}
      child_issues={@child_issues}
      tool_call_traces={@tool_call_traces}
      all_agents={@all_agents}
      child_health_cards={@child_health_cards}
    />

    <CymphoWeb.IssueLive.Show.ChildIssues.child_issues
      child_tree={@child_tree}
      child_health_cards={@child_health_cards}
    />

    <CymphoWeb.IssueLive.Show.ActivityTimeline.activity_timeline
      timeline={@timeline}
      timeline_filter={@timeline_filter}
      all_agents={@all_agents}
    />

    <CymphoWeb.IssueLive.Show.Comments.comments
      comment_form={@comment_form}
      comment_templates={@comment_templates}
    />
  </div>

  <CymphoWeb.IssueLive.Show.Sidebar.sidebar
    issue={@issue}
    all_agents={@all_agents}
    orchestrator_enabled?={@orchestrator_enabled?}
    show_agent_panel={@show_agent_panel}
    agents={@agents}
    documents={@documents}
  />
</div>
