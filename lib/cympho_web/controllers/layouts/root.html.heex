<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title><%= Map.get(assigns, :page_title, "Cympho") %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
  </head>
  <body class="bg-canvas text-text-primary font-inter antialiased min-h-screen">
    <div class="flex min-h-screen">
      <aside class="w-60 bg-panel border-r border-border-subtle flex flex-col fixed inset-y-0 left-0 z-50 lg:translate-x-0 -translate-x-full transition-transform duration-200" id="sidebar">
        <div class="h-14 flex items-center px-4 border-b border-border-subtle">
          <a href="/" class="text-lg font-590 tracking-tight text-text-primary">Cympho</a>
        </div>
        <nav class="flex-1 py-4 px-3 space-y-1">
          <a href="/issues" class="flex items-center gap-3 px-3 py-2 rounded-md text-sm font-510 text-text-secondary hover:text-text-primary hover:bg-white/[0.04] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            Issues
          </a>
          <a href="/projects" class="flex items-center gap-3 px-3 py-2 rounded-md text-sm font-510 text-text-secondary hover:text-text-primary hover:bg-white/[0.04] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            Projects
          </a>
          <a href="/kanban" class="flex items-center gap-3 px-3 py-2 rounded-md text-sm font-510 text-text-secondary hover:text-text-primary hover:bg-white/[0.04] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
            Kanban
          </a>
          <a href="/agents" class="flex items-center gap-3 px-3 py-2 rounded-md text-sm font-510 text-text-secondary hover:text-text-primary hover:bg-white/[0.04] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.131A8 8 0 008 3.239c-4.828 4.596-5.212 11.611-.647 16.656A21.866 21.866 0 0012 21.942a21.866 21.866 0 003.99-.385M19.337 17.81a15.79 15.79 0 01-2.326 1.575"/></svg>
            Agents
          </a>
        </nav>
      </aside>
      <div class="lg:hidden fixed top-3 left-3 z-50">
        <button type="button" onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')" class="p-2 rounded-md bg-panel border border-border text-text-secondary hover:text-text-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
      <main class="flex-1 lg:ml-60 min-h-screen">
        <%= @inner_content %>
      </main>
    </div>
  </body>
</html>
